## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ww][Ii][Nn][33]2/

# Visual Studio 2015/2017/2019/2022 cache build results
.vs/
# Unlock the vsidx files
.vs/*/FileContentIndex/*.vsidx

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.*

# Build log of MSBuild
*.log

# Visual Studio Professional 2012+ persistence file
*.v12.suo

# Project-specific overrides
/.agent

# Entity Framework 6+ (e.g. EF Core)
*.Migrations.cs
# (Keep migrations in source control usually, but ignore user specific tools)

# Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# Local Config
appsettings.Local.json
appsettings.json
!appsettings.json
!appsettings.Development.json

# Packages
/packages
/node_modules
/bin
/obj

# OS generated files
.DS_Store
Thumbs.db